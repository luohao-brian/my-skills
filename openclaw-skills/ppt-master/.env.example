# Optional web image search configuration for scripts/image_search.py.
# AI image generation and narration do not read this file. They use the
# current runtime's image-generation and TTS tools.

# Openverse and Wikimedia need no key. Pexels and Pixabay are optional
# additional web image sources.
# PEXELS_API_KEY=your-pexels-key
# PIXABAY_API_KEY=your-pixabay-key

# Optional search concurrency.
# IMAGE_SEARCH_CONCURRENCY=3
